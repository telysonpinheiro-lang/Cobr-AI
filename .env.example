# ============================================================
# Cobr-AI — Variáveis de Ambiente (copie para .env e preencha)
# ============================================================
# Gere senhas seguras com:
#   openssl rand -hex 32

# ── Servidor ────────────────────────────────────────────────
SERVER_IP=SEU_IP_AQUI
BACKEND_PORT=4010

# ── JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=TROQUE_PARA_SEGREDO_FORTE

# ── MySQL ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=TROQUE_PARA_SENHA_ROOT_FORTE
MYSQL_PASSWORD=TROQUE_PARA_SENHA_COBRAI_FORTE

# ── Evolution API ────────────────────────────────────────────
EVOLUTION_API_KEY=TROQUE_PARA_CHAVE_EVOLUTION_FORTE
EVOLUTION_INSTANCE=cobrai

# ── Redis (Evolution API) ────────────────────────────────────
REDIS_PASSWORD=TROQUE_PARA_SENHA_REDIS_FORTE

# ── PostgreSQL (Evolution API) ───────────────────────────────
PG_PASSWORD=TROQUE_PARA_SENHA_PG_FORTE

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── WhatsApp Provider ────────────────────────────────────────
WHATSAPP_PROVIDER=evolution

# ── Payment Provider ─────────────────────────────────────────
PAYMENT_PROVIDER=mock
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
PAGARME_API_KEY=

# ── Webhook de Pagamento (HMAC) ──────────────────────────────
# Gere com: openssl rand -hex 32
WEBHOOK_PAYMENT_SECRET=
