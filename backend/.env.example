# Server
PORT=4000
NODE_ENV=development

# SEGURANÇA: gere um segredo forte com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_PARA_UM_SEGREDO_FORTE_E_ALEATORIO

# CORS: lista de origens permitidas separadas por vírgula (NUNCA use * em produção)
CORS_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=cobrai_user
DB_PASSWORD=TROQUE_PARA_SENHA_FORTE
DB_NAME=cobrai

# OpenAI (deixe vazio p/ usar mock)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp provider: mock | zapi | evolution
WHATSAPP_PROVIDER=evolution
ZAPI_INSTANCE=
ZAPI_TOKEN=

# Evolution API — rode scripts/setup-evolution.sh no servidor para obter os valores
EVOLUTION_BASE_URL=http://SEU_IP:8080
EVOLUTION_API_KEY=sua_api_key_gerada
EVOLUTION_INSTANCE=cobrai

# Payment provider: mock | asaas | pagarme
PAYMENT_PROVIDER=mock
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
PAGARME_API_KEY=

# SEGURANÇA: segredo HMAC para verificar webhooks de pagamento
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_PAYMENT_SECRET=
